---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { categories, getCategoryLabel } from '../data/categories';
import { tagStyle } from '../utils/tagColor';

const allPosts = await getCollection('posts');

const recentPosts = [...allPosts]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const totalPosts = allPosts.length;

const categoryCounts = categories
  .map((cat) => ({
    ...cat,
    count: allPosts.filter((p) => p.data.category === cat.slug).length,
  }))
  .filter((cat) => cat.count > 0);

const maxCount = Math.max(...categoryCounts.map((c) => c.count), 1);

const FEATURED_ID = 'rsa';
const featuredPost = allPosts.find((p) => p.id === FEATURED_ID);
---

<BaseLayout title="홈">
  <div class="prose home">

    <!-- 에디토리얼 헤드라인 -->
    <h1 class="headline">
      <span class="headline-hl">배운 것</span>을<br />정리하는 개발자
    </h1>
    <p class="desc">
      Unity 클라이언트 개발, CS 이론, UI/UX 구현 과정을 기록합니다.<br />
      결과보다 과정과 이유를 남기는 것을 중요하게 생각합니다.
    </p>

    <!-- 기술 태그 -->
    <div class="tags">
      <span class="tag tag--accent">Unity</span>
      <span class="tag tag--accent">C#</span>
      <span class="tag tag--accent">UI 설계</span>
      <span class="tag">TypeScript</span>
      <span class="tag">C++</span>
      <span class="tag">알고리즘</span>
      <span class="tag">CS 이론</span>
    </div>

    <div class="divider"></div>

    <!-- 수평 카테고리 탭 -->
    <nav class="cat-nav" aria-label="카테고리">
      <a class="cat-item cat-active" href="/blog">
        전체 <span class="cat-n">{totalPosts}</span>
      </a>
      {categoryCounts.map((cat) => (
        <a class="cat-item" href={`/categories/${cat.slug}`}>
          {cat.label} <span class="cat-n">{cat.count}</span>
        </a>
      ))}
    </nav>

    <!-- Featured Post -->
    {featuredPost && (
      <a href={`/blog/${featuredPost.id}`} class="featured">
        <span class="featured-label">추천 글</span>
        <div class="featured-title">{featuredPost.data.title}</div>
        {featuredPost.data.description && (
          <div class="featured-desc">{featuredPost.data.description}</div>
        )}
      </a>
    )}

    <!-- 최근 글 피드 -->
    <div class="feed-head">
      <h2 class="feed-label">최근 글</h2>
      <a href="/blog" class="feed-more">모두 보기 →</a>
    </div>
    <div class="feed">
      {recentPosts.map((post) => (
        <a href={`/blog/${post.id}`} class="feed-item">
          <span class="feed-date">
            {post.data.date.toLocaleDateString('ko-KR', { month: '2-digit', day: '2-digit' })}
          </span>
          <span class="feed-cat">{post.data.category ?? '—'}</span>
          <span class="feed-title">{post.data.title}</span>
        </a>
      ))}
    </div>

    <div class="section-divider"></div>

    <!-- 카테고리별 포스트 통계 -->
    <div class="section-head">
      <h2 class="section-label">주제별 현황</h2>
      <span class="section-total">총 <strong>{totalPosts}</strong>개</span>
    </div>
    <ul class="bar-list">
      {categoryCounts.map((cat) => (
        <li class="bar-item">
          <span class="bar-label">{cat.label}</span>
          <div class="bar-track">
            <div
              class="bar-fill"
              data-scale={`${(cat.count / maxCount).toFixed(3)}`}
              style="transform: scaleX(0)"
            />
          </div>
          <span class="bar-count">{cat.count}</span>
        </li>
      ))}
    </ul>


  </div>
</BaseLayout>

<script>
  const bars = document.querySelectorAll<HTMLElement>('.bar-fill');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const scale = el.dataset.scale ?? '1';
          if (reduced) {
            el.style.transition = 'none';
          }
          el.style.transform = `scaleX(${scale})`;
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.3 }
  );
  bars.forEach((bar) => observer.observe(bar));
</script>

<style>
  /* ── 에디토리얼 헤드라인 ── */
  .headline {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.04em;
    color: var(--text);
    margin: 1.5rem 0 0.75rem;
    border: none;
    text-wrap: balance;
  }
  .headline-hl { color: var(--accent); }

  .desc {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.75;
    margin: 0 0 1.25rem;
    text-wrap: pretty;
  }

  /* ── 기술 태그 ── */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 1.75rem;
  }
  .tag {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    padding: 0.2rem 0.65rem;
    border-radius: 3px;
    background: rgba(74, 85, 104, 0.2);
    color: var(--text-dim);
    border: 1px solid rgba(74, 85, 104, 0.3);
  }
  .tag--accent {
    background: var(--accent-dim);
    color: var(--accent);
    border-color: rgba(249, 115, 22, 0.3);
  }

  .divider {
    height: 1px;
    background: rgba(74, 85, 104, 0.2);
    margin-bottom: 1.5rem;
  }

  /* ── 카테고리 탭 ── */
  .cat-nav {
    display: flex;
    gap: 0;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(74, 85, 104, 0.2);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .cat-nav::-webkit-scrollbar { display: none; }

  .cat-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.65rem 1rem;
    min-height: 40px;
    font-size: 0.92rem;
    color: var(--text-dim);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s, border-color 0.15s, transform 0.1s;
    white-space: nowrap;
  }
  .cat-item:hover { color: var(--text); border-bottom-color: rgba(249, 115, 22, 0.4); }
  .cat-item:active { transform: scale(0.96); }
  .cat-active { color: var(--accent); border-bottom-color: var(--accent); font-weight: 600; }

  .cat-n {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
  }

  /* ── Featured Post ── */
  .featured {
    display: block;
    padding: 1.1rem 1.4rem;
    background: var(--bg-card);
    border-radius: 10px;
    box-shadow:
      -3px 0 0 0 var(--accent),
      0 0 0 1px rgba(74, 85, 104, 0.2);
    margin-bottom: 1.75rem;
    text-decoration: none;
    transition: box-shadow 0.15s, background 0.15s, transform 0.1s;
  }
  .featured:hover {
    background: rgba(249, 115, 22, 0.04);
    box-shadow:
      -3px 0 0 0 var(--accent),
      0 0 0 1px rgba(249, 115, 22, 0.25);
  }
  .featured:active { transform: scale(0.99); }

  .featured-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    font-weight: 700;
  }
  .featured-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    margin: 0.3rem 0 0.35rem;
  }
  .featured-desc {
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.6;
    text-wrap: pretty;
  }

  /* ── 피드 ── */
  .feed-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.55rem;
  }
  .feed-label {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
  }
  .feed-more {
    font-size: 0.78rem;
    color: var(--text-dim);
    text-decoration: none;
    padding: 0.5rem 0.25rem;
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    transition: color 0.15s;
  }
  .feed-more:hover { color: var(--accent); }

  .feed { display: flex; flex-direction: column; }
  .feed-item {
    display: grid;
    grid-template-columns: 4.5rem auto 1fr;
    align-items: baseline;
    gap: 0.75rem;
    padding: 1.1rem 0.4rem;
    border-bottom: 1px solid rgba(74, 85, 104, 0.1);
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.12s, transform 0.1s;
  }
  .feed-item:last-child { border-bottom: none; }
  .feed-item:hover { background: rgba(255, 255, 255, 0.03); }
  .feed-item:hover .feed-title { color: var(--text); }
  .feed-item:active { transform: scale(0.99); }

  .feed-date  {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    font-variant-numeric: tabular-nums;
  }
  .feed-cat   {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    white-space: nowrap;
  }
  .feed-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.12s;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── 섹션 공통 ── */
  .section-divider {
    height: 1px;
    background: rgba(74, 85, 104, 0.2);
    margin: 2rem 0 1.5rem;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .section-label {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
  }
  .section-total {
    font-size: 0.82rem;
    color: var(--text-dim);
  }
  .section-total strong {
    color: var(--accent);
    font-weight: 700;
  }

  /* ── 바 차트 ── */
  .bar-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .bar-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .bar-label {
    font-size: 0.82rem;
    color: var(--text-muted);
    width: 5.5rem;
    flex-shrink: 0;
  }
  .bar-track {
    flex: 1;
    height: 6px;
    background: rgba(74, 85, 104, 0.2);
    border-radius: 3px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    width: 100%;
    background: var(--accent);
    border-radius: 3px;
    transform-origin: left;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .bar-count {
    font-size: 0.8rem;
    color: var(--text-dim);
    width: 1.5rem;
    text-align: right;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  @media (prefers-reduced-motion: reduce) {
    .bar-fill { transition: none; }
    .cat-item, .featured, .feed-item, .feed-more { transition: none; }
    .cat-item:active, .featured:active, .feed-item:active { transform: none; }
  }

  /* ── 반응형 ── */
  @media (max-width: 480px) {
    .headline { font-size: 1.65rem; }
    .identity-role { display: none; }
    .feed-item { grid-template-columns: 3.5rem 1fr; }
    .feed-cat { display: none; }
  }
</style>
