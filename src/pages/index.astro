---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { categories } from '../data/categories';

const allPosts = await getCollection('posts');

const recentPosts = [...allPosts]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const totalPosts = allPosts.length;

const categoryCounts = categories
  .map((cat) => ({
    ...cat,
    count: allPosts.filter((p) => p.data.category === cat.slug).length,
  }))
  .filter((cat) => cat.count > 0);

const maxCount = Math.max(...categoryCounts.map((c) => c.count), 1);
---

<BaseLayout title="홈">
  <div class="prose home">

    <!-- 섹션 1: 프로필 헤더 -->
    <section class="home-hero">
      <img
        src="https://github.com/XsQuare01.png"
        alt="XsQuare01 프로필 사진"
        class="home-avatar"
      />
      <div class="home-intro">
        <h1 class="home-name">XsQuare01</h1>
        <p class="home-tagline">게임 클라이언트와 UI 구현에 집중하는 개발자</p>
        <p class="home-desc">
          사용자 경험이 자연스럽게 느껴지는 화면과 인터랙션을 만드는 데 관심이 있습니다.<br />
          Unity 기반 클라이언트 개발, UI 설계와 구현, 그리고 문제 해결을 위한 CS 학습 과정을 기록합니다.
        </p>
        <p class="home-links">
          Seoul &nbsp;·&nbsp;
          <a href="https://github.com/XsQuare01" target="_blank" rel="noopener noreferrer">GitHub</a>
          &nbsp;·&nbsp;
          <a href="mailto:mystic6113@naver.com">이메일</a>
        </p>
      </div>
    </section>

    <!-- 섹션: About Me -->
    <section class="home-section">
      <h2>About Me</h2>
      <p class="about-text">
        저는 사용자 경험을 직접 만드는 클라이언트 개발자를 지향합니다.<br />
        특히 Unity 기반 개발에서 UI와 상호작용, 화면 흐름, 구조 설계에 관심이 많습니다.
      </p>
      <p class="about-text">
        이 블로그에는 단순한 결과만 남기지 않으려고 합니다.<br />
        왜 이런 구조를 선택했는지, 어떤 문제를 만났고 어떻게 해결했는지, 그리고 그 과정에서 무엇을 배웠는지를 기록합니다.
      </p>
    </section>

    <!-- 섹션 2: What I Do -->
    <section class="home-section">
      <h2>What I Do</h2>
      <div class="what-grid">
        <div class="what-card">
          <h3 class="what-title">게임 클라이언트 개발</h3>
          <p class="what-desc">플레이 경험을 구성하는 기능과 흐름을 구현합니다.<br />입력, 상태 변화, 인터랙션, 연출이 자연스럽게 이어지도록 구조를 고민합니다.</p>
        </div>
        <div class="what-card">
          <h3 class="what-title">UI / UX 구현</h3>
          <p class="what-desc">화면을 단순히 배치하는 데서 끝내지 않고,<br />사용자가 보기 쉽고 쓰기 편한 흐름을 코드와 연출로 풀어내는 데 집중합니다.</p>
        </div>
        <div class="what-card">
          <h3 class="what-title">CS / 알고리즘 기록</h3>
          <p class="what-desc">구현의 깊이를 만들기 위해 컴퓨터 사이언스와 알고리즘을 꾸준히 공부합니다.<br />문제를 푸는 과정과 개념을 이해한 방식까지 함께 정리합니다.</p>
        </div>
      </div>
    </section>

    <!-- 섹션 3: 기술 스택 -->
    <section class="home-section">
      <h2>Tech Stack</h2>
      <div class="stack-list">
        <div class="stack-row">
          <span class="stack-label">Main</span>
          <span class="stack-items">Unity, C#, C++, UI 설계 및 구현</span>
        </div>
        <div class="stack-row">
          <span class="stack-label">Experienced With</span>
          <span class="stack-items">TypeScript, Python, Git, 웹 프론트엔드/도구 활용</span>
        </div>
        <div class="stack-row">
          <span class="stack-label">Interested In</span>
          <span class="stack-items">알고리즘, 컴퓨터 사이언스, 클라이언트 구조 설계, 인터랙션 최적화</span>
        </div>
      </div>
    </section>

    <!-- 섹션 3: 최근 포스트 -->
    <section class="home-section">
      <div class="section-header">
        <h2>Recent Posts</h2>
        <a href="/blog" class="view-all">대표 글 보기 →</a>
      </div>
      <ul class="post-list post-list--bordered" style="margin-top: 1.25rem;">
        {recentPosts.map((post) => (
          <li class="post-item">
            <a href={`/blog/${post.id}`} class="post-item-link" aria-label={post.data.title}></a>
            <span class="post-item-date">
              {post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
            <span class="post-item-title">{post.data.title}</span>
            {post.data.description && (
              <p class="post-item-desc">{post.data.description}</p>
            )}
          </li>
        ))}
      </ul>
    </section>

    <!-- 섹션 4: Activity -->
    <section class="home-section">
      <h2>Activity</h2>
      <p class="stats-desc">학습과 개발 과정에서 쌓인 기록들입니다.<br />세부적인 수치보다 꾸준히 만들고 정리하는 흐름을 중요하게 생각합니다.</p>
      <div class="stats-grid">
        <div class="stats-cell">
          <img
            src="https://github-readme-stats.vercel.app/api?username=XsQuare01&show_icons=true&theme=dark&hide_border=true&bg_color=161b22"
            alt="XsQuare01's GitHub Stats"
            loading="lazy"
            class="stats-img"
          />
        </div>
        <div class="stats-cell">
          <img
            src="https://mazassumnida.wtf/api/v2/generate_badge?boj=mystic6113"
            alt="solved.ac 티어"
            loading="lazy"
            class="stats-img"
          />
        </div>
        <div class="post-stats-card">
          <div>
            <p class="post-stats-header">Post Stats</p>
            <p class="post-stats-total-row">총 <span class="post-stats-total">{totalPosts}</span>개</p>
          </div>
          <ul class="post-bar-list">
            {categoryCounts.map((cat) => (
              <li class="post-bar-item">
                <span class="post-bar-label">{cat.label}</span>
                <div class="post-bar-track">
                  <div
                    class="post-bar-fill"
                    style={`width: ${Math.round((cat.count / maxCount) * 100)}%`}
                  />
                </div>
                <span class="post-bar-count">{cat.count}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .home-hero {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .home-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    flex-shrink: 0;
    object-fit: cover;
  }

  .home-intro {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .home-name {
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    border: none;
    margin: 0;
    line-height: 1.2;
  }

  .home-tagline {
    font-size: 0.95rem;
    color: var(--accent);
    font-weight: 500;
    margin: 0;
  }

  .home-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0.25rem 0 0;
  }

  .home-links {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin: 0;
  }

  .home-section {
    margin-bottom: 3rem;
  }

  .stack-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .stack-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .stack-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-dim);
    width: 7.5rem;
    flex-shrink: 0;
  }

  .stack-items {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .what-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .what-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid rgba(74, 85, 104, 0.35);
    border-radius: 10px;
    transition: border-color 0.2s;
  }

  .what-card:hover {
    border-color: var(--accent);
  }

  .what-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    margin: 0;
  }

  .what-desc {
    font-size: 0.83rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 768px) {
    .what-grid {
      grid-template-columns: 1fr;
    }
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0;
  }

  .section-header h2 {
    margin: 0;
  }

  .view-all {
    font-size: 0.82rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .view-all:hover {
    color: var(--accent);
  }

  .stats-desc {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0.75rem 0 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-top: 1rem;
    align-items: stretch;
  }

  .stats-cell {
    display: flex;
  }

  .stats-img {
    width: 100%;
    height: 150px;
    object-fit: cover;
    object-position: top;
    border-radius: 6px;
    display: block;
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
    .stats-img {
      height: auto;
    }
  }

  .about-text {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 0.75rem;
  }

  .post-stats-card {
    background: #161b22;
    border: 1px solid rgba(74, 85, 104, 0.4);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 150px;
  }

  .post-stats-header {
    font-size: 0.8rem;
    font-weight: 700;
    color: #e6edf3;
    margin: 0;
    letter-spacing: 0.01em;
  }

  .post-stats-total-row {
    font-size: 0.7rem;
    color: #8b949e;
    margin: 0.2rem 0 0;
  }

  .post-stats-total {
    font-weight: 700;
    color: var(--accent);
  }

  .post-bar-list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.42rem;
    flex: 1;
    justify-content: flex-end;
  }

  .post-bar-item {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .post-bar-label {
    font-size: 0.7rem;
    color: #8b949e;
    width: 4rem;
    flex-shrink: 0;
  }

  .post-bar-track {
    flex: 1;
    height: 4px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 2px;
    overflow: hidden;
  }

  .post-bar-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
    min-width: 4px;
  }

  .post-bar-count {
    font-size: 0.68rem;
    color: #8b949e;
    width: 1.2rem;
    text-align: right;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .home-hero {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
