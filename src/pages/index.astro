---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { categories, getCategoryLabel } from '../data/categories';
import { tagStyle } from '../utils/tagColor';

const allPosts = await getCollection('posts');

const recentPosts = [...allPosts]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const totalPosts = allPosts.length;

const categoryCounts = categories
  .map((cat) => ({
    ...cat,
    count: allPosts.filter((p) => p.data.category === cat.slug).length,
  }))
  .filter((cat) => cat.count > 0);

const maxCount = Math.max(...categoryCounts.map((c) => c.count), 1);

const FEATURED_IDS = ['rsa', 'algo-orientation'];
const featuredPosts = FEATURED_IDS.map((id) => allPosts.find((p) => p.id === id)).filter(Boolean);

// 홈 구조화 데이터 — 사이트(WebSite)와 저자(Person) 엔티티
const siteUrl = Astro.site?.toString() ?? 'https://xsquare01.github.io/';
const homeJsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'XsQuare01',
    alternateName: 'XsQuare01 학습 노트',
    url: siteUrl,
    inLanguage: 'ko',
    description: '계산 이론·암호학·알고리즘을 정의부터 증명까지 정리하는 학습 노트',
    author: { '@type': 'Person', name: 'XsQuare01', url: siteUrl },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'XsQuare01',
    url: siteUrl,
    image: 'https://github.com/XsQuare01.png',
    knowsAbout: ['계산 이론', '암호학', '알고리즘', '정수론', '복잡도', '그리디'],
  },
]);
---

<BaseLayout title="홈">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={homeJsonLd} />
  </Fragment>
  <div class="prose home">

    <!-- 에디토리얼 헤드라인 -->
    <h1 class="headline">
      <span class="headline-hl">배운 것</span>을<br />정리하는 개발자
    </h1>
    <p class="desc">
      계산 이론·암호학·알고리즘을 정의부터 증명까지 풀어 정리하는 노트입니다.<br />
      정답보다 그 답에 이르는 과정을 우선합니다.
    </p>

    <!-- 기술 태그 -->
    <div class="tags">
      <span class="tag tag--accent">계산 이론</span>
      <span class="tag tag--accent">암호학</span>
      <span class="tag tag--accent">알고리즘</span>
      <span class="tag">정수론</span>
      <span class="tag">복잡도</span>
      <span class="tag">그리디</span>
    </div>

    <div class="divider"></div>

    <!-- 수평 카테고리 탭 -->
    <nav class="cat-nav" aria-label="카테고리">
      <a class="cat-item cat-active" href="/blog">
        전체 <span class="cat-n">{totalPosts}</span>
      </a>
      {categoryCounts.map((cat) => (
        <a class="cat-item" href={`/categories/${cat.slug}`}>
          {cat.label} <span class="cat-n">{cat.count}</span>
        </a>
      ))}
    </nav>

    <!-- Featured Posts -->
    {featuredPosts.length > 0 && (
      <div class="featured-grid">
        {featuredPosts.map((post) => (
          <a href={`/blog/${post!.id}`} class="featured">
            <span class="featured-label">추천 글</span>
            <div class="featured-title">{post!.data.title}</div>
            {post!.data.description && (
              <div class="featured-desc">{post!.data.description}</div>
            )}
          </a>
        ))}
      </div>
    )}

    <!-- 최근 글 피드 -->
    <div class="feed-head">
      <h2 class="feed-label">최근 글</h2>
      <a href="/blog" class="feed-more">모두 보기 →</a>
    </div>
    <div class="feed">
      {recentPosts.map((post) => (
        <a href={`/blog/${post.id}`} class="feed-item">
          <span class="feed-date">
            {post.data.date.toLocaleDateString('ko-KR', { month: '2-digit', day: '2-digit' })}
          </span>
          <span class="feed-cat">{post.data.category ? getCategoryLabel(post.data.category) : '—'}</span>
          <span class="feed-title">{post.data.title}</span>
        </a>
      ))}
    </div>

    <div class="section-divider"></div>

    <!-- 카테고리별 포스트 통계 -->
    <div class="section-head">
      <h2 class="section-label">주제별 현황</h2>
      <span class="section-total">총 <strong>{totalPosts}</strong>개</span>
    </div>
    <ul class="bar-list">
      {categoryCounts.map((cat) => (
        <li>
          <a href={`/categories/${cat.slug}`} class="bar-item">
            <span class="bar-label">{cat.label}</span>
            <div class="bar-track">
              <div
                class="bar-fill"
                style={`transform: scaleX(${(cat.count / maxCount).toFixed(3)})`}
              />
            </div>
            <span class="bar-count">{cat.count}</span>
          </a>
        </li>
      ))}
    </ul>


  </div>
</BaseLayout>

<style>
  .home {
    position: relative;
  }

  /* ── 에디토리얼 헤드라인 ── */
  .headline {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 1.5rem 0 0.75rem;
    border: none;
    text-wrap: balance;
  }
  .headline-hl {
    color: var(--accent);
  }

  .desc {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.75;
    margin: 0 0 1.25rem;
    text-wrap: pretty;
  }

  /* ── 기술 태그 ── */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 1.75rem;
  }
  .tag {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    padding: 0.2rem 0.65rem;
    border-radius: 4px;
    background: var(--amber-soft);
    color: var(--amber);
    border: 1px solid transparent;
  }
  .tag--accent {
    background: var(--amber-soft);
    color: var(--amber);
    border-color: var(--amber);
  }

  .divider {
    height: 1px;
    background: var(--rule);
    margin-bottom: 1.5rem;
  }

  /* ── 카테고리 탭 ── */
  .cat-nav {
    display: flex;
    gap: 0;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .cat-nav::-webkit-scrollbar { display: none; }

  .cat-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.65rem 1rem;
    min-height: 44px;
    font-size: 0.92rem;
    color: var(--text-dim);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.25s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.25s cubic-bezier(0.16, 1, 0.3, 1), transform 0.15s cubic-bezier(0.16, 1, 0.3, 1);
    white-space: nowrap;
    touch-action: manipulation;
  }
  .cat-item:hover { color: var(--text); border-bottom-color: var(--amber); }
  .cat-item:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
    border-radius: 4px;
  }
  .cat-active { color: var(--accent); border-bottom-color: var(--accent); font-weight: 600; }

  .cat-n {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
  }

  /* ── Featured Posts ── */
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .featured {
    display: block;
    position: relative;
    overflow: hidden;
    padding: 1.1rem 1.4rem;
    background: var(--bg-card);
    border-radius: 10px;
    box-shadow:
      -3px 0 0 0 var(--accent),
      0 0 0 1px var(--rule);
    text-decoration: none;
    transition: box-shadow 0.25s cubic-bezier(0.16, 1, 0.3, 1), background 0.25s cubic-bezier(0.16, 1, 0.3, 1), transform 0.15s cubic-bezier(0.16, 1, 0.3, 1);
    touch-action: manipulation;
  }
  .featured:hover {
    background: var(--amber-soft);
    box-shadow:
      -3px 0 0 0 var(--accent),
      0 0 0 1px var(--amber);
  }
  .featured:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  .featured-label {
    font-size: 0.68rem;
    letter-spacing: 0;
    color: var(--accent);
    font-weight: 700;
  }
  .featured-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    margin: 0.3rem 0 0.35rem;
  }
  .featured-desc {
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.6;
    text-wrap: pretty;
  }

  /* ── 피드 ── */
  .feed-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.55rem;
  }
  .feed-label {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
  }
  .feed-more {
    font-size: 0.78rem;
    color: var(--text-dim);
    text-decoration: none;
    padding: 0.5rem 0.25rem;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    transition: color 0.15s;
    touch-action: manipulation;
  }
  .feed-more:hover { color: var(--accent); }
  .feed-more:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 3px;
  }

  .feed { display: flex; flex-direction: column; }
  .feed-item {
    display: grid;
    grid-template-columns: 4.5rem auto 1fr;
    align-items: baseline;
    gap: 0.75rem;
    padding: 1.1rem 0.4rem;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.2s cubic-bezier(0.16, 1, 0.3, 1), transform 0.15s cubic-bezier(0.16, 1, 0.3, 1);
    touch-action: manipulation;
  }
  .feed-item:last-child { border-bottom: none; }
  .feed-item:hover { background: var(--bg-hover); }
  .feed-item:hover .feed-title { color: var(--text); }
  .feed-item:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .feed-date  {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    font-variant-numeric: tabular-nums;
  }
  .feed-cat   {
    font-family: var(--font-serif);
    font-size: 0.82rem;
    color: var(--text-dim);
    white-space: nowrap;
  }
  .feed-title {
    font-family: var(--font-serif);
    font-size: 1.02rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.12s;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── 섹션 공통 ── */
  .section-divider {
    height: 1px;
    background: var(--rule);
    margin: 2rem 0 1.5rem;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .section-label {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
  }
  .section-total {
    font-size: 0.82rem;
    color: var(--text-dim);
  }
  .section-total strong {
    color: var(--accent);
    font-weight: 700;
  }

  /* ── 바 차트 ── */
  .bar-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .bar-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    padding: 0.25rem 0.4rem;
    margin: 0 -0.4rem;
    border-radius: 6px;
    transition: background 0.12s;
    touch-action: manipulation;
  }
  .bar-item:hover { background: var(--bg-hover); }
  .bar-item:hover .bar-label { color: var(--text); }
  .bar-item:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .bar-label {
    font-size: 0.82rem;
    color: var(--text-muted);
    width: 5.5rem;
    flex-shrink: 0;
  }
  .bar-track {
    flex: 1;
    height: 6px;
    background: var(--rule);
    border-radius: 3px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    width: 100%;
    background: var(--accent);
    border-radius: 3px;
    transform-origin: left;
  }
  .bar-count {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    width: 2rem;
    text-align: right;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  @media (prefers-reduced-motion: reduce) {
    .bar-fill { transition: none; }
    .cat-item, .featured, .feed-item, .feed-more { transition: none; }
    .cat-item:active, .featured:active, .feed-item:active { transform: none; }
    .cat-item:focus-visible, .featured:focus-visible, .feed-item:focus-visible, .feed-more:focus-visible {
      transition: none;
    }
    .feed-item { animation: none; }
    .featured::after { transition: none; }
  }

  /* ── 반응형 ── */
  @media (max-width: 480px) {
    .headline { font-size: 1.65rem; }
    .identity-role { display: none; }
    .featured-grid { grid-template-columns: 1fr; }
    .feed-item { grid-template-columns: 3.5rem 1fr; }
    .feed-cat { display: none; }
  }
</style>
