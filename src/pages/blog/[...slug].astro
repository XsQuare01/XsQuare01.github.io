---
import PostLayout from '../../layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return sorted.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prevPost: sorted[index + 1] ?? null,
      nextPost: sorted[index - 1] ?? null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);

// post.body에서 ## 헤딩 원문을 추출 — remark-math가 $...$를 제거하기 전 텍스트 보존
const rawH2Texts = (post.body ?? '')
  .split('\n')
  .filter((line) => line.startsWith('## '))
  .map((line) => line.replace(/^## /, ''));

const h2Headings = headings
  .filter((h) => h.depth === 2)
  .map((h, i) => ({ slug: h.slug, text: rawH2Texts[i] ?? h.text }));

// 읽기 시간 계산 (분)
const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.round(wordCount / 130));
---

<PostLayout
  title={post.data.title}
  date={post.data.date}
  description={post.data.description}
  tags={post.data.tags}
  category={post.data.category}
  headings={h2Headings}
  readingTime={readingTime}
  prevPost={prevPost ? { slug: prevPost.id, title: prevPost.data.title, description: prevPost.data.description } : undefined}
  nextPost={nextPost ? { slug: nextPost.id, title: nextPost.data.title, description: nextPost.data.description } : undefined}
>
  <Content />
</PostLayout>
