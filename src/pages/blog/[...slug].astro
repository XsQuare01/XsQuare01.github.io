---
import PostLayout from '../../layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';
import { extractFirstImage, absoluteImageUrl } from '../../utils/extractFirstImage';

export async function getStaticPaths() {
  const SERP_DESCRIPTION_LIMIT = 160;
  const posts = await getCollection('posts');

  // SEO 경고: SERP에서 잘리지 않으려면 description 160자 이하 권장
  for (const post of posts) {
    const desc = post.data.description;
    if (desc && desc.length > SERP_DESCRIPTION_LIMIT) {
      console.warn(
        `[SEO] ${post.id}.md: description ${desc.length}자 (권장 ${SERP_DESCRIPTION_LIMIT}자 이하) — SERP에서 잘릴 가능성`
      );
    }
  }

  const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return sorted.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prevPost: sorted[index + 1] ?? null,
      nextPost: sorted[index - 1] ?? null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);

// post.body에서 ## 헤딩 원문을 추출 — remark-math가 $...$를 제거하기 전 텍스트 보존
const rawH2Texts = (post.body ?? '')
  .split('\n')
  .filter((line) => line.startsWith('## '))
  .map((line) => line.replace(/^## /, ''));

const h2Headings = headings
  .filter((h) => h.depth === 2)
  .map((h, i) => ({ slug: h.slug, text: rawH2Texts[i] ?? h.text }));

// 읽기 시간 계산 (분)
const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.round(wordCount / 130));

// og:image / JSON-LD image 용도로 본문 첫 이미지 추출 (없으면 undefined → 기본 아바타로 fallback)
const firstImage = extractFirstImage(post.body ?? '');
const siteOrigin = Astro.site?.toString() ?? 'https://xsquare01.github.io';
const ogImageUrl = firstImage ? absoluteImageUrl(firstImage, siteOrigin) : undefined;
---

<PostLayout
  title={post.data.title}
  date={post.data.date}
  description={post.data.description}
  tags={post.data.tags}
  category={post.data.category}
  difficulty={post.data.difficulty}
  headings={h2Headings}
  readingTime={readingTime}
  wordCount={wordCount}
  ogImageUrl={ogImageUrl}
  prevPost={prevPost ? { slug: prevPost.id, title: prevPost.data.title, description: prevPost.data.description } : undefined}
  nextPost={nextPost ? { slug: nextPost.id, title: nextPost.data.title, description: nextPost.data.description } : undefined}
>
  <Content />
</PostLayout>
