---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { tagStyle } from '../../utils/tagColor';
import { getCategoryLabel } from '../../data/categories';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const pageDescription = 'XsQuare01 학습 노트의 전체 글 목록입니다. 계산 이론·암호학·알고리즘을 정의부터 증명까지 정리합니다.';
const siteUrl = Astro.site?.toString() ?? 'https://xsquare01.github.io';
const blogUrl = new URL('/blog/', siteUrl).toString();
const blogJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'XsQuare01 글 목록',
  description: pageDescription,
  url: blogUrl,
  inLanguage: 'ko',
  blogPost: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description ?? '',
    datePublished: post.data.date.toISOString(),
    url: new URL(`/blog/${post.id}/`, siteUrl).toString(),
  })),
});
---

<BaseLayout title="글 목록" description={pageDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={blogJsonLd} />
  </Fragment>

  <h1 class="page-title">글 목록</h1>
  <ul class="post-list">
    {posts.map((post) => (
      <li class="post-item">
        <a href={`/blog/${post.id}`} class="post-item-link" aria-label={post.data.title}></a>
        <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
          <span class="post-item-date">
            {post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
          {post.data.category && (
            <a href={`/categories/${post.data.category}`} class="post-category-badge" style={tagStyle(post.data.category)}>
              {getCategoryLabel(post.data.category)}
            </a>
          )}
        </div>
        <span class="post-item-title">
          {post.data.title}
        </span>
        {post.data.description && (
          <p class="post-item-desc">{post.data.description}</p>
        )}
        {post.data.tags.length > 0 && (
          <div class="tags">
            {post.data.tags.map((tag) => (
              <a href={`/tags/${tag}`} class="tag" style={tagStyle(tag)}>{tag}</a>
            ))}
          </div>
        )}
      </li>
    ))}
  </ul>
</BaseLayout>
