---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/categories';
import { tagStyle } from '../../utils/tagColor';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return categories.map((cat) => ({
    params: { category: cat.slug },
    props: {
      label: cat.label,
      posts: posts
        .filter((p) => p.data.category === cat.slug)
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { label, posts } = Astro.props;
---

<BaseLayout title={label}>
  <h1 class="page-title">{label}</h1>
  {posts.length === 0 ? (
    <p style="color: var(--text-muted);">아직 글이 없습니다.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item">
          <a href={`/blog/${post.id}`} class="post-item-link" aria-label={post.data.title}></a>
          <span class="post-item-date">
            {post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
          <span class="post-item-title">
            {post.data.title}
          </span>
          {post.data.description && (
            <p class="post-item-desc">{post.data.description}</p>
          )}
          {post.data.tags.length > 0 && (
            <div class="tags">
              {post.data.tags.map((tag) => (
                <a href={`/tags/${tag}`} class="tag" style={tagStyle(tag)}>{tag}</a>
              ))}
            </div>
          )}
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
