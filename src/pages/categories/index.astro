---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/categories';

const posts = await getCollection('posts');

const countByCategory: Record<string, number> = {};
for (const post of posts) {
  if (post.data.category) {
    countByCategory[post.data.category] = (countByCategory[post.data.category] ?? 0) + 1;
  }
}

const activeCategories = categories.filter((cat) => (countByCategory[cat.slug] ?? 0) > 0);
---

<BaseLayout title="카테고리">
  <h1 class="page-title">카테고리</h1>
  <div class="category-grid">
    {activeCategories.map((cat) => (
      <a href={`/categories/${cat.slug}`} class="category-card">
        <span class="category-name">{cat.label}</span>
        <span class="category-desc">{cat.description}</span>
        <span class="category-count">{countByCategory[cat.slug]} posts</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .category-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .category-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: all 0.25s;
  }

  .category-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }

  .category-name {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
  }

  .category-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.5;
    flex: 1;
    white-space: pre-line;
  }

  .category-count {
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  @media (max-width: 640px) {
    .category-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
