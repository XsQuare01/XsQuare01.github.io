---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/categories';

const posts = await getCollection('posts');

const countByCategory: Record<string, number> = {};
for (const post of posts) {
  if (post.data.category) {
    countByCategory[post.data.category] = (countByCategory[post.data.category] ?? 0) + 1;
  }
}

const activeCategories = categories.filter((cat) => (countByCategory[cat.slug] ?? 0) > 0);
---

<BaseLayout title="카테고리">
  <h1 class="page-title">카테고리</h1>
  <p class="page-sub">주제별 학습 장(章). 각 장은 정의부터 증명까지 이어지는 글 묶음입니다.</p>

  <ul class="chapter-list">
    {activeCategories.map((cat) => (
      <li>
        <a href={`/categories/${cat.slug}`} class="chapter">
          <span class="chapter-head">
            <span class="chapter-title">{cat.label}</span>
            <span class="chapter-count">{countByCategory[cat.slug]}편</span>
          </span>
          <span class="chapter-desc">{cat.description}</span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .chapter-list {
    list-style: none;
    margin-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }

  .chapter {
    display: block;
    padding: 1.25rem 0.6rem;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
    transition: background 0.15s;
  }
  .chapter:hover { background: var(--accent-dim); }

  .chapter-head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
  }
  .chapter-title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
  }
  .chapter:hover .chapter-title { color: var(--accent); }
  .chapter-count {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }
  .chapter-desc {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    white-space: pre-line;
    max-width: 42em;
  }
</style>
