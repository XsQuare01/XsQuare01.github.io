---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { tagStyle } from '../../utils/tagColor';
import { getCategoryLabel } from '../../data/categories';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: { tag, posts: posts.filter((p) => p.data.tags.includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`#${tag}`}>
  <h1 class="page-title"># {tag}</h1>
  <ul class="post-list">
    {sorted.map((post) => (
      <li class="post-item">
        <a href={`/blog/${post.id}`} class="post-item-link" aria-label={post.data.title}></a>
        <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
          <span class="post-item-date">
            {post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
          {post.data.category && (
            <a href={`/categories/${post.data.category}`} class="post-category-badge" style={tagStyle(post.data.category)}>
              {getCategoryLabel(post.data.category)}
            </a>
          )}
        </div>
        <span class="post-item-title">
          {post.data.title}
        </span>
        {post.data.description && (
          <p class="post-item-desc">{post.data.description}</p>
        )}
      </li>
    ))}
  </ul>
</BaseLayout>
