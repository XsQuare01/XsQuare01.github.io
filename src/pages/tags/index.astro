---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const tagCount: Record<string, number> = {};

for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCount[tag] = (tagCount[tag] ?? 0) + 1;
  }
}

const tags = Object.entries(tagCount).sort((a, b) => b[1] - a[1]);

const maxCount = Math.max(...tags.map(([, c]) => c));
const minCount = Math.min(...tags.map(([, c]) => c));

function getTagSize(count: number): string {
  if (maxCount === minCount) return '0.9rem';
  const ratio = (count - minCount) / (maxCount - minCount);
  const size = 0.78 + ratio * 0.7; // 0.78rem ~ 1.48rem
  return `${size.toFixed(2)}rem`;
}
---

<BaseLayout title="태그">
  <h1 class="page-title">태그</h1>
  <div class="tag-cloud">
    {tags.map(([tag, count]) => (
      <a
        href={`/tags/${tag}`}
        class="tag"
        style={`font-size: ${getTagSize(count)}; padding: 0.25rem 0.7rem;`}
      >
        {tag}
        <span style="opacity:0.5; font-size:0.8em"> {count}</span>
      </a>
    ))}
  </div>
</BaseLayout>
