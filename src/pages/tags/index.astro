---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const tagCount: Record<string, number> = {};

for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCount[tag] = (tagCount[tag] ?? 0) + 1;
  }
}

const tags = Object.entries(tagCount).sort((a, b) => a[0].localeCompare(b[0]));
---

<BaseLayout title="태그">
  <h1 class="page-title">태그</h1>
  <p class="page-sub">모든 태그 색인 — 총 {tags.length}개. 가나다·알파벳 순.</p>

  <ul class="tag-index">
    {tags.map(([tag, count]) => (
      <li class="ti-item">
        <a href={`/tags/${tag}`} class="ti">
          <span class="ti-name">{tag}</span>
          <span class="ti-count">{count}</span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .tag-index {
    list-style: none;
    margin-top: 1.5rem;
    columns: 3;
    column-gap: 2.5rem;
  }
  .ti-item { break-inside: avoid; }

  .ti {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.6rem;
    padding: 0.32rem 0;
    border-bottom: 1px dotted var(--rule);
    text-decoration: none;
  }
  .ti-name {
    font-size: 0.88rem;
    color: var(--text-muted);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ti:hover .ti-name { color: var(--accent); }
  .ti-count {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--text-dim);
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 720px) { .tag-index { columns: 2; column-gap: 1.75rem; } }
  @media (max-width: 420px) { .tag-index { columns: 1; } }
</style>
