---
import { getCollection } from 'astro:content';
import { categories } from '../data/categories';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'XsQuare01의 기술 블로그',
  ogImage = 'https://github.com/XsQuare01.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const posts = await getCollection('posts');
const tagCount: Record<string, number> = {};
const categoryCount: Record<string, number> = {};
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCount[tag] = (tagCount[tag] ?? 0) + 1;
  }
  if (post.data.category) {
    categoryCount[post.data.category] = (categoryCount[post.data.category] ?? 0) + 1;
  }
}
const topTags = Object.entries(tagCount)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map(([tag]) => tag);
const activeCategories = categories.filter((cat) => (categoryCount[cat.slug] ?? 0) > 0);

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} | XsQuare01`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={`${title} | XsQuare01`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <title>{title} | XsQuare01</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'light' || (!stored && !prefersDark)) {
        document.documentElement.classList.add('light');
      }
    })();
  </script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-35YPC8K6Y2"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-35YPC8K6Y2');
  </script>

  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-MWXXL2TH');</script>
  <!-- End Google Tag Manager -->
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MWXXL2TH"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <aside class="sidebar">
    <div class="sidebar-profile">
      <img class="sidebar-avatar" src="https://github.com/XsQuare01.png" alt="XsQuare01 프로필 사진" />
      <div class="sidebar-name">XsQuare01</div>
      <div class="sidebar-bio">배운 것을 정리하고 남깁니다</div>
    </div>

    <button id="search-btn" aria-label="검색">
      <span id="search-btn-icon">🔍</span>
      검색
      <kbd id="search-btn-kbd">Ctrl K</kbd>
    </button>

    <nav class="sidebar-nav">
      <div class="sidebar-nav-label">메뉴</div>
      <a href="/" class={currentPath === '/' ? 'active' : ''}>홈</a>
      <a href="/blog" class={currentPath.startsWith('/blog') ? 'active' : ''}>글 목록</a>
      <a href="/categories" class={currentPath.startsWith('/categories') ? 'active' : ''}>카테고리</a>
      <a href="/tags" class={currentPath.startsWith('/tags') ? 'active' : ''}>태그</a>
    </nav>

    <div class="sidebar-categories">
      <div class="sidebar-nav-label">카테고리</div>
      {activeCategories.map((cat) => (
        <a
          href={`/categories/${cat.slug}`}
          class={`sidebar-category-link${currentPath === `/categories/${cat.slug}` ? ' active' : ''}`}
        >
          {cat.label}
          <span class="sidebar-category-count">{categoryCount[cat.slug]}</span>
        </a>
      ))}
    </div>

    {topTags.length > 0 && (
      <div class="sidebar-tags">
        <div class="sidebar-nav-label">태그</div>
        <div class="tag-list">
          {topTags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">{tag}</a>
          ))}
        </div>
      </div>
    )}

    <div class="sidebar-footer">
      <button id="theme-toggle" aria-label="테마 전환">
        <span class="theme-toggle-icon theme-icon-moon">☽</span>
        <span class="theme-toggle-icon theme-icon-sun">☀</span>
        <span class="theme-label-light">라이트 모드</span>
        <span class="theme-label-dark">다크 모드</span>
      </button>
      <div style="margin-top:0.5rem;">© {new Date().getFullYear()} XsQuare01</div>
    </div>
  </aside>

  <div class="main-wrap">
    <div class="main-row">
      <div class="main-content">
        <slot />
        <footer class="site-footer">
          <span>© {new Date().getFullYear()} XsQuare01. Powered by GitHub Pages.</span>
        </footer>
      </div>
      <aside class="right-panel">
        <slot name="toc" />
      </aside>
    </div>
  </div>

  <button id="back-to-top" aria-label="맨 위로">↑</button>

  <div id="search-modal" role="dialog" aria-modal="true" aria-label="검색">
    <div class="search-modal-box">
      <div class="search-modal-input-row">
        <span class="search-modal-icon">🔍</span>
        <input
          id="search-input"
          type="text"
          placeholder="검색어를 입력하세요..."
          autocomplete="off"
          spellcheck="false"
        />
        <span class="search-modal-esc">esc</span>
      </div>
      <div id="search-results"></div>
    </div>
  </div>
</body>
</html>

<script>
  import Fuse from 'fuse.js';

  // ── 검색 모달 ──
  const modal = document.getElementById('search-modal') as HTMLElement;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results') as HTMLElement;

  let fuse: InstanceType<typeof Fuse> | null = null;

  async function loadIndex() {
    if (fuse) return;
    const res = await fetch('/search-index.json');
    const data = await res.json();
    fuse = new Fuse(data, {
      keys: [
        { name: 'title',       weight: 0.5 },
        { name: 'description', weight: 0.25 },
        { name: 'tags',        weight: 0.15 },
        { name: 'category',    weight: 0.10 },
      ],
      threshold: 0.4,
      minMatchCharLength: 2,
    });
  }

  function openModal() {
    modal.classList.add('open');
    searchInput.focus();
    loadIndex();
  }

  function closeModal() {
    modal.classList.remove('open');
    searchInput.value = '';
    searchResults.innerHTML = '';
  }

  document.getElementById('search-btn')?.addEventListener('click', openModal);

  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      modal.classList.contains('open') ? closeModal() : openModal();
    }
    if (e.key === 'Escape') closeModal();
  });

  searchInput.addEventListener('input', () => {
    const query = searchInput.value.trim();
    if (!query || !fuse) {
      searchResults.innerHTML = '';
      return;
    }

    const results = fuse.search(query, { limit: 8 });
    if (results.length === 0) {
      searchResults.innerHTML = `<div class="search-empty">결과 없음</div>`;
      return;
    }

    searchResults.innerHTML = results
      .map(({ item }) => `
        <a class="search-result-item" href="/blog/${item.id}">
          <span class="search-result-title">${item.title}</span>
          ${item.category ? `<span class="search-result-badge">${item.category}</span>` : ''}
        </a>
      `)
      .join('');

    attachKeyNav();
  });

  function attachKeyNav() {
    const items = searchResults.querySelectorAll<HTMLAnchorElement>('.search-result-item');
    let idx = -1;

    searchInput.onkeydown = (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        items[idx]?.classList.remove('focused');
        idx = Math.min(idx + 1, items.length - 1);
        items[idx]?.classList.add('focused');
        items[idx]?.scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        items[idx]?.classList.remove('focused');
        idx = Math.max(idx - 1, 0);
        items[idx]?.scrollIntoView({ block: 'nearest' });
        items[idx]?.classList.add('focused');
      } else if (e.key === 'Enter' && idx >= 0) {
        items[idx]?.click();
      }
    };
  }

  const btn = document.getElementById('back-to-top');
  window.addEventListener('scroll', () => {
    btn?.classList.toggle('visible', window.scrollY > 300);
  }, { passive: true });
  btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isLight = document.documentElement.classList.toggle('light');
    localStorage.setItem('theme', isLight ? 'light' : 'dark');
  });
</script>

<style is:global>
  @import '../styles/global.css';
</style>
