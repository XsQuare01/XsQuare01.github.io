---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'XsQuare01의 기술 블로그' } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | XsQuare01</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
</head>
<body>
  <header>
    <div class="container">
      <a href="/" class="site-title">XsQuare01</a>
      <nav>
        <a href="/">글</a>
        <a href="/tags">태그</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <slot />
  </main>

  <footer>
    <div class="container">
      © {new Date().getFullYear()} XsQuare01
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
