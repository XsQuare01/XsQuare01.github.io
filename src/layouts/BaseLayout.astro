---
import { getCollection } from 'astro:content';
import { categories } from '../data/categories';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'XsQuare01의 기술 블로그',
  ogImage = 'https://github.com/XsQuare01.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const posts = await getCollection('posts');
const tagCount: Record<string, number> = {};
const categoryCount: Record<string, number> = {};
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCount[tag] = (tagCount[tag] ?? 0) + 1;
  }
  if (post.data.category) {
    categoryCount[post.data.category] = (categoryCount[post.data.category] ?? 0) + 1;
  }
}
const topTags = Object.entries(tagCount)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([tag]) => tag);
const activeCategories = categories.filter((cat) => (categoryCount[cat.slug] ?? 0) > 0);

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} | XsQuare01`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={`${title} | XsQuare01`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <title>{title} | XsQuare01</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-35YPC8K6Y2"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-35YPC8K6Y2');
  </script>

  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-MWXXL2TH');</script>
  <!-- End Google Tag Manager -->
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MWXXL2TH"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <aside class="sidebar">
    <div class="sidebar-profile">
      <img class="sidebar-avatar" src="https://github.com/XsQuare01.png" alt="XsQuare01 프로필 사진" />
      <div class="sidebar-name">XsQuare01</div>
      <div class="sidebar-bio">기록하는 개발자</div>
    </div>

    <nav class="sidebar-nav">
      <div class="sidebar-nav-label">메뉴</div>
      <a href="/" class={currentPath === '/' ? 'active' : ''}>홈</a>
      <a href="/blog" class={currentPath.startsWith('/blog') ? 'active' : ''}>글 목록</a>
      <a href="/categories" class={currentPath.startsWith('/categories') ? 'active' : ''}>카테고리</a>
      <a href="/tags" class={currentPath.startsWith('/tags') ? 'active' : ''}>태그</a>
    </nav>

    <div class="sidebar-categories">
      <div class="sidebar-nav-label">카테고리</div>
      {activeCategories.map((cat) => (
        <a
          href={`/categories/${cat.slug}`}
          class={`sidebar-category-link${currentPath === `/categories/${cat.slug}` ? ' active' : ''}`}
        >
          {cat.label}
        </a>
      ))}
    </div>

    {topTags.length > 0 && (
      <div class="sidebar-tags">
        <div class="sidebar-nav-label">태그</div>
        <div class="tag-list">
          {topTags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">{tag}</a>
          ))}
        </div>
      </div>
    )}

    <div class="sidebar-footer">
      © {new Date().getFullYear()} XsQuare01
    </div>
  </aside>

  <div class="main-wrap">
    <div class="main-row">
      <div class="main-content">
        <slot />
        <footer class="site-footer">
          <span>© {new Date().getFullYear()} XsQuare01. Powered by GitHub Pages.</span>
        </footer>
      </div>
      <aside class="right-panel">
        <slot name="toc" />
      </aside>
    </div>
  </div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
