---
import { getCollection } from 'astro:content';
import { categories } from '../data/categories';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'XsQuare01의 기술 블로그' } = Astro.props;

const posts = await getCollection('posts');
const tagCount: Record<string, number> = {};
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCount[tag] = (tagCount[tag] ?? 0) + 1;
  }
}
const topTags = Object.entries(tagCount)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([tag]) => tag);

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | XsQuare01</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
</head>
<body>
  <aside class="sidebar">
    <div class="sidebar-profile">
      <div class="sidebar-avatar">🔐</div>
      <div class="sidebar-name">XsQuare01</div>
      <div class="sidebar-bio">기록하는 개발자</div>
    </div>

    <nav class="sidebar-nav">
      <div class="sidebar-nav-label">메뉴</div>
      <a href="/" class={currentPath === '/' ? 'active' : ''}>
        📝 &nbsp;글 목록
      </a>
      <a href="/categories" class={currentPath.startsWith('/categories') ? 'active' : ''}>
        📂 &nbsp;카테고리
      </a>
      <a href="/tags" class={currentPath.startsWith('/tags') ? 'active' : ''}>
        🏷️ &nbsp;태그
      </a>
    </nav>

    <div class="sidebar-categories">
      <div class="sidebar-nav-label">카테고리</div>
      {categories.map((cat) => (
        <a
          href={`/categories/${cat.slug}`}
          class={`sidebar-category-link${currentPath === `/categories/${cat.slug}` ? ' active' : ''}`}
        >
          {cat.label}
        </a>
      ))}
    </div>

    {topTags.length > 0 && (
      <div class="sidebar-tags">
        <div class="sidebar-nav-label">태그</div>
        <div class="tag-list">
          {topTags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">{tag}</a>
          ))}
        </div>
      </div>
    )}

    <div class="sidebar-footer">
      © {new Date().getFullYear()} XsQuare01
    </div>
  </aside>

  <div class="main-wrap">
    <slot />
    <footer class="site-footer">
      <div class="site-footer-top">
        <span class="site-footer-name">XsQuare01</span>
        <span class="site-footer-bio">기록하는 개발자</span>
      </div>
      <div class="site-footer-bottom">
        <span>© {new Date().getFullYear()} XsQuare01</span>
        <a href="https://github.com/XsQuare01" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="mailto:mystic6113@naver.com">이메일</a>
      </div>
    </footer>
  </div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
