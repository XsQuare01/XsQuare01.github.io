---
import { getCollection } from 'astro:content';
import { categories } from '../data/categories';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = 'XsQuare01의 기술 블로그',
  ogImage = 'https://github.com/XsQuare01.png',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const posts = await getCollection('posts');
const tagCount: Record<string, number> = {};
const categoryCount: Record<string, number> = {};
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCount[tag] = (tagCount[tag] ?? 0) + 1;
  }
  if (post.data.category) {
    categoryCount[post.data.category] = (categoryCount[post.data.category] ?? 0) + 1;
  }
}
const topTags = Object.entries(tagCount)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map(([tag]) => tag);
const activeCategories = categories.filter((cat) => (categoryCount[cat.slug] ?? 0) > 0);

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="ko" style="color-scheme: dark light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0f1117" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} | XsQuare01`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={`${title} | XsQuare01`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <title>{title} | XsQuare01</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'light' || (!stored && !prefersDark)) {
        document.documentElement.classList.add('light');
      }
    })();
  </script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
  <slot name="head" />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-35YPC8K6Y2"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-35YPC8K6Y2');
  </script>

  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-MWXXL2TH');</script>
  <!-- End Google Tag Manager -->
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MWXXL2TH"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <button id="sidebar-toggle" class="sidebar-toggle" aria-label="메뉴 열기/닫기">
    <span class="sidebar-toggle-icon sidebar-icon-open">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <line x1="2" y1="5" x2="16" y2="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="2" y1="9" x2="16" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="2" y1="13" x2="16" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </span>
    <span class="sidebar-toggle-icon sidebar-icon-close" style="display:none">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <line x1="4" y1="4" x2="14" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="14" y1="4" x2="4" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </span>
  </button>
  <aside class="sidebar">
    <div class="sidebar-profile">
      <img class="sidebar-avatar" src="https://github.com/XsQuare01.png" alt="XsQuare01 프로필 사진" />
      <div class="sidebar-name">XsQuare01</div>
      <div class="sidebar-bio">정리하고 기록하는 개발자</div>
    </div>

    <button id="search-btn" aria-label="검색">
      <span id="search-btn-icon">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
          <circle cx="6.5" cy="6.5" r="4" stroke="currentColor" stroke-width="1.5"/>
          <line x1="9.65" y1="9.65" x2="13" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </span>
      검색
      <kbd id="search-btn-kbd">Ctrl K</kbd>
    </button>

    <nav class="sidebar-nav">
      <div class="sidebar-nav-label">메뉴</div>
      <a href="/" class={currentPath === '/' ? 'active' : ''}>홈</a>
      <a href="/blog" class={currentPath.startsWith('/blog') ? 'active' : ''}>글 목록</a>
      <a href="/categories" class={currentPath.startsWith('/categories') ? 'active' : ''}>카테고리</a>
      <a href="/tags" class={currentPath.startsWith('/tags') ? 'active' : ''}>태그</a>
    </nav>

    <div class="sidebar-categories">
      <div class="sidebar-nav-label">카테고리</div>
      {activeCategories.map((cat) => (
        <a
          href={`/categories/${cat.slug}`}
          class={`sidebar-category-link${currentPath === `/categories/${cat.slug}` ? ' active' : ''}`}
        >
          {cat.label}
          <span class="sidebar-category-count">{categoryCount[cat.slug]}</span>
        </a>
      ))}
    </div>

    {topTags.length > 0 && (
      <div class="sidebar-tags">
        <div class="sidebar-nav-label">태그</div>
        <div class="tag-list">
          {topTags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">{tag}</a>
          ))}
        </div>
      </div>
    )}

    <div class="sidebar-footer">
      <button id="theme-toggle" aria-label="테마 전환">
        <span class="theme-toggle-icon theme-icon-moon">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
            <path d="M12.5 9A5.5 5.5 0 0 1 6 2.5 5 5 0 1 0 12.5 9z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="theme-toggle-icon theme-icon-sun">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
            <circle cx="7.5" cy="7.5" r="2.5" stroke="currentColor" stroke-width="1.5"/>
            <line x1="7.5" y1="1" x2="7.5" y2="2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="7.5" y1="12.5" x2="7.5" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="1" y1="7.5" x2="2.5" y2="7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="12.5" y1="7.5" x2="14" y2="7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="3.05" y1="3.05" x2="4.11" y2="4.11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="10.89" y1="10.89" x2="11.95" y2="11.95" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="3.05" y1="11.95" x2="4.11" y2="10.89" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="10.89" y1="4.11" x2="11.95" y2="3.05" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="theme-label-light">라이트 모드</span>
        <span class="theme-label-dark">다크 모드</span>
      </button>
      <div style="margin-top:0.5rem;">© {new Date().getFullYear()} XsQuare01</div>
    </div>
  </aside>

  <div class="main-wrap">
    <div class="main-row">
      <div class="main-content">
        <slot />
        <footer class="site-footer">
          <span>© {new Date().getFullYear()} XsQuare01. Powered by GitHub Pages.</span>
        </footer>
      </div>
      <aside class="right-panel">
        <slot name="toc" />
      </aside>
    </div>
  </div>

  <button id="back-to-top" aria-label="맨 위로">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <line x1="8" y1="13" x2="8" y2="3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <polyline points="4,7 8,3 12,7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div id="search-modal" role="dialog" aria-modal="true" aria-label="검색">
    <div class="search-modal-box">
      <div class="search-modal-input-row">
        <span class="search-modal-icon">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
            <circle cx="6.5" cy="6.5" r="4" stroke="currentColor" stroke-width="1.5"/>
            <line x1="9.65" y1="9.65" x2="13" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </span>
        <input
          id="search-input"
          type="text"
          placeholder="검색어를 입력하세요..."
          autocomplete="off"
          spellcheck="false"
        />
        <span class="search-modal-esc">esc</span>
      </div>
      <div id="search-results"></div>
    </div>
  </div>
</body>
</html>

<script>
  import Fuse from 'fuse.js';

  // ── 검색 모달 ──
  const modal = document.getElementById('search-modal') as HTMLElement;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results') as HTMLElement;

  let fuse: InstanceType<typeof Fuse> | null = null;
  let navIdx = -1;  // idx는 모달 스코프에서 관리

  function escHtml(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  async function loadIndex() {
    if (fuse) return;
    try {
      const res = await fetch('/search-index.json');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      fuse = new Fuse(data, {
        keys: [
          { name: 'title',       weight: 0.5 },
          { name: 'description', weight: 0.25 },
          { name: 'tags',        weight: 0.15 },
          { name: 'category',    weight: 0.10 },
        ],
        threshold: 0.4,
        minMatchCharLength: 2,
      });
    } catch {
      searchResults.innerHTML = `<div class="search-empty">인덱스 로드 실패</div>`;
    }
  }

  function openModal() {
    modal.classList.add('open');
    searchInput.focus();
    loadIndex();
  }

  function closeModal() {
    modal.classList.remove('open');
    searchInput.value = '';
    searchResults.innerHTML = '';
    navIdx = -1;
  }

  function renderResults(query: string) {
    if (!query || !fuse) {
      searchResults.innerHTML = '';
      navIdx = -1;
      return;
    }
    const results = fuse.search(query, { limit: 20 });
    searchResults.innerHTML = '';
    navIdx = -1;
    if (results.length === 0) {
      searchResults.innerHTML = `<div class="search-empty">결과 없음</div>`;
      return;
    }
    results.forEach(({ item }) => {
      const a = document.createElement('a');
      a.className = 'search-result-item';
      a.href = `/blog/${escHtml(item.id)}`;
      const title = document.createElement('span');
      title.className = 'search-result-title';
      title.textContent = item.title;
      a.appendChild(title);
      if (item.category) {
        const badge = document.createElement('span');
        badge.className = 'search-result-badge';
        badge.textContent = item.category;
        a.appendChild(badge);
      }
      searchResults.appendChild(a);
    });
  }

  document.getElementById('search-btn')?.addEventListener('click', openModal);

  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      modal.classList.contains('open') ? closeModal() : openModal();
    }
    if (e.key === 'Escape') closeModal();
  });

  searchInput.addEventListener('input', () => {
    renderResults(searchInput.value.trim());
  });

  searchInput.addEventListener('keydown', (e) => {
    const items = searchResults.querySelectorAll<HTMLAnchorElement>('.search-result-item');
    if (!items.length) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      items[navIdx]?.classList.remove('focused');
      navIdx = Math.min(navIdx + 1, items.length - 1);
      items[navIdx]?.classList.add('focused');
      items[navIdx]?.scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      items[navIdx]?.classList.remove('focused');
      navIdx = navIdx <= 0 ? -1 : navIdx - 1;
      if (navIdx >= 0) {
        items[navIdx]?.classList.add('focused');
        items[navIdx]?.scrollIntoView({ block: 'nearest' });
      } else {
        searchInput.focus();
      }
    } else if (e.key === 'Enter' && navIdx >= 0) {
      items[navIdx]?.click();
    }
  });

  const btn = document.getElementById('back-to-top');
  window.addEventListener('scroll', () => {
    btn?.classList.toggle('visible', window.scrollY > 300);
  }, { passive: true });
  btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isLight = document.documentElement.classList.toggle('light');
    localStorage.setItem('theme', isLight ? 'light' : 'dark');
  });

  // ── 모바일 사이드바 토글 ──
  const sidebarToggle = document.getElementById('sidebar-toggle');
  const sidebar = document.querySelector('.sidebar');
  sidebarToggle?.addEventListener('click', () => {
    sidebar?.classList.toggle('open');
    const isOpen = sidebar?.classList.contains('open');
    sidebarToggle.setAttribute('aria-expanded', String(isOpen));
    const iconOpen = sidebarToggle.querySelector('.sidebar-icon-open') as HTMLElement | null;
    const iconClose = sidebarToggle.querySelector('.sidebar-icon-close') as HTMLElement | null;
    if (iconOpen) iconOpen.style.display = isOpen ? 'none' : '';
    if (iconClose) iconClose.style.display = isOpen ? '' : 'none';
  });
</script>

<style is:global>
  @import '../styles/global.css';
</style>
