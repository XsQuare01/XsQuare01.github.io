---
import BaseLayout from './BaseLayout.astro';
import { tagStyle } from '../utils/tagColor';
import { getCategoryLabel } from '../data/categories';
import { difficultyStars } from '../utils/difficulty';
import katex from 'katex';

function renderHeadingText(text: string): string {
  return text.replace(/\$([^$]+)\$/g, (_, math) => {
    try {
      return katex.renderToString(math, { throwOnError: false });
    } catch {
      return `$${math}$`;
    }
  });
}

interface Heading {
  slug: string;
  text: string;
}

interface PostLink {
  slug: string;
  title: string;
  description?: string;
}

interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  category?: string;
  difficulty?: '입문' | '초급' | '중급' | '고급' | '심화';
  numbered?: boolean;
  headings?: Heading[];
  readingTime?: number;
  wordCount?: number;
  ogImageUrl?: string;
  prevPost?: PostLink;
  nextPost?: PostLink;
}

const {
  title,
  date,
  description,
  tags = [],
  category,
  difficulty,
  numbered = false,
  headings = [],
  readingTime,
  wordCount,
  ogImageUrl,
  prevPost,
  nextPost,
} = Astro.props;

const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const siteUrl = Astro.site?.toString() ?? '';
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const categoryLabel = category ? getCategoryLabel(category) : undefined;

const blogPosting: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description ?? '',
  inLanguage: 'ko',
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'XsQuare01',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Person',
    name: 'XsQuare01',
    url: siteUrl,
  },
  url: canonicalURL,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
};
if (ogImageUrl) blogPosting.image = ogImageUrl;
if (wordCount) blogPosting.wordCount = wordCount;
if (tags.length > 0) blogPosting.keywords = tags.join(', ');
if (categoryLabel) blogPosting.articleSection = categoryLabel;

const breadcrumbItems: Array<Record<string, unknown>> = [
  { '@type': 'ListItem', position: 1, name: '홈', item: siteUrl },
];
if (category && categoryLabel) {
  breadcrumbItems.push({
    '@type': 'ListItem',
    position: 2,
    name: categoryLabel,
    item: new URL(`categories/${category}/`, Astro.site).toString(),
  });
}
breadcrumbItems.push({
  '@type': 'ListItem',
  position: breadcrumbItems.length + 1,
  name: title,
  item: canonicalURL,
});
const breadcrumbList = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
};

const jsonLd = JSON.stringify([blogPosting, breadcrumbList]);
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={ogImageUrl}
  ogImageAlt={title}
  twitterCardType="summary_large_image"
  articlePublishedTime={date.toISOString()}
  articleModifiedTime={date.toISOString()}
  articleAuthor="XsQuare01"
  articleSection={categoryLabel}
  articleTags={tags}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  {headings.length > 0 && (
    <Fragment slot="toc">
      <div class="toc">
        <div class="toc-title">목차</div>
        <ul class="toc-list">
          {headings.map((h) => (
            <li>
              <a class="toc-link" href={`#${h.slug}`} set:html={renderHeadingText(h.text)} />
            </li>
          ))}
        </ul>
      </div>
    </Fragment>
  )}

  <article>
    {category && (
      <nav class="post-breadcrumb" aria-label="breadcrumb">
        <a href="/">홈</a>
        <span class="post-breadcrumb-sep">›</span>
        <a href={`/categories/${category}`}>{getCategoryLabel(category)}</a>
        <span class="post-breadcrumb-sep">›</span>
        <span>{title}</span>
      </nav>
    )}
    <div class="post-header">
      <h1>{title}</h1>
      <div class="post-meta">
        <span>{formattedDate}</span>
        {readingTime && (
          <span class="reading-time">· 약 {readingTime}분 읽기</span>
        )}
        {difficulty && (
          <span class={`difficulty-badge difficulty-${difficulty}`}>
            {difficultyStars(difficulty)} {difficulty}
          </span>
        )}
        {tags.length > 0 && (
          <div class="tags">
            {tags.map((tag) => (
              <a href={`/tags/${tag}`} class="tag" style={tagStyle(tag)}>{tag}</a>
            ))}
          </div>
        )}
      </div>
    </div>

    <div class:list={['prose', { numbered }]}>
      <slot />
    </div>

    {(prevPost || nextPost) && (
      <nav class="post-nav">
        {nextPost ? (
          <a href={`/blog/${nextPost.slug}`} class="post-nav-item prev">
            <span class="post-nav-label">← 다음 글</span>
            <span class="post-nav-title">{nextPost.title}</span>
            {nextPost.description && <span class="post-nav-desc">{nextPost.description}</span>}
          </a>
        ) : <div />}
        {prevPost ? (
          <a href={`/blog/${prevPost.slug}`} class="post-nav-item next">
            <span class="post-nav-label">이전 글 →</span>
            <span class="post-nav-title">{prevPost.title}</span>
            {prevPost.description && <span class="post-nav-desc">{prevPost.description}</span>}
          </a>
        ) : <div />}
      </nav>
    )}
  </article>

  {headings.length > 0 && (
    <div class="mtoc" data-mtoc>
      <button
        class="mtoc-fab"
        type="button"
        aria-label="목차 열기"
        aria-haspopup="dialog"
        aria-expanded="false"
        aria-controls="mtoc-sheet"
      >
        <span class="mtoc-bars" aria-hidden="true"></span>
      </button>
      <div class="mtoc-backdrop" data-mtoc-backdrop></div>
      <div class="mtoc-sheet" id="mtoc-sheet" role="dialog" aria-modal="true" aria-label="목차" tabindex="-1">
        <div class="mtoc-grip" aria-hidden="true"></div>
        <div class="mtoc-head"><span class="mtoc-cap">목차</span></div>
        <nav class="mtoc-body" aria-label="목차">
          <ul class="mtoc-list">
            {headings.map((h, i) => (
              <li>
                <a class="mtoc-link" href={`#${h.slug}`}>
                  <span class="mtoc-n">{i + 1}</span>
                  <span set:html={renderHeadingText(h.text)} />
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </div>
  )}
</BaseLayout>

<script>
  // ── 읽기 진행률 바 ──
  const bar = document.createElement('div');
  bar.id = 'reading-progress';
  bar.setAttribute('aria-hidden', 'true');
  document.body.appendChild(bar);

  function updateProgress() {
    const article = document.querySelector('article');
    if (!article) return;
    const { top, height } = article.getBoundingClientRect();
    const scrolled = Math.min(1, Math.max(0, -top / (height - window.innerHeight)));
    bar.style.width = `${scrolled * 100}%`;
  }

  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();

  // ── 코드 블록 복사 버튼 ──
  document.querySelectorAll('.prose pre').forEach((pre) => {
    const btn = document.createElement('button');
    btn.className = 'code-copy-btn';
    btn.textContent = 'Copy';
    btn.setAttribute('aria-label', '코드 복사');
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code');
      if (!code) return;
      try {
        await navigator.clipboard.writeText(code.innerText);
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
      } catch {
        btn.textContent = '복사 실패';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      }
    });
    (pre as HTMLElement).style.position = 'relative';
    pre.appendChild(btn);
  });

  // ── 이미지 라이트박스 ──
  const lightbox = document.createElement('div');
  lightbox.id = 'image-lightbox';
  lightbox.setAttribute('role', 'dialog');
  lightbox.setAttribute('aria-modal', 'true');
  lightbox.setAttribute('aria-label', '이미지 확대');
  lightbox.innerHTML = `
    <div class="lightbox-backdrop"></div>
    <div class="lightbox-content"></div>
    <button class="lightbox-close" type="button" aria-label="닫기">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <line x1="3" y1="3" x2="13" y2="13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        <line x1="13" y1="3" x2="3" y2="13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
    </button>`;
  document.body.appendChild(lightbox);

  const closeBtn = lightbox.querySelector('.lightbox-close') as HTMLButtonElement;
  let lastFocused: HTMLElement | null = null;

  function closeLightbox() {
    lightbox.classList.remove('open');
    lightbox.querySelector('.lightbox-content')!.innerHTML = '';
    if (lastFocused) {
      lastFocused.focus();
      lastFocused = null;
    }
  }

  lightbox.querySelector('.lightbox-backdrop')!.addEventListener('click', closeLightbox);
  closeBtn.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox.classList.contains('open')) closeLightbox();
  });

  document.querySelectorAll('.prose img').forEach((img) => {
    (img as HTMLElement).style.cursor = 'zoom-in';
    img.addEventListener('click', () => {
      lastFocused = document.activeElement as HTMLElement;
      const clone = img.cloneNode(true) as HTMLImageElement;
      clone.style.cursor = 'zoom-out';
      clone.removeAttribute('width');
      clone.removeAttribute('height');
      clone.addEventListener('click', closeLightbox);
      const content = lightbox.querySelector('.lightbox-content')!;
      content.innerHTML = '';
      content.appendChild(clone);
      lightbox.classList.add('open');
      closeBtn.focus();
    });
  });

  // ── TOC 활성 링크 ──
  const headings = document.querySelectorAll('article h2[id]');
  const tocLinks = document.querySelectorAll('.toc-link');

  if (headings.length > 0 && tocLinks.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => {
              link.classList.remove('active');
              link.removeAttribute('aria-current');
            });
            const active = document.querySelector(
              `.toc-link[href="#${entry.target.id}"]`
            );
            if (active) {
              active.classList.add('active');
              active.setAttribute('aria-current', 'true');
            }
          }
        }
      },
      { rootMargin: '0px 0px -80% 0px' }
    );
    headings.forEach((h) => observer.observe(h));
  }

  // ── 모바일 목차 (FAB + 바텀시트, ≤768px) ──
  const mtoc = document.querySelector('[data-mtoc]');
  if (mtoc) {
    const fab = mtoc.querySelector('.mtoc-fab') as HTMLButtonElement;
    const backdrop = mtoc.querySelector('.mtoc-backdrop') as HTMLElement;
    const sheet = mtoc.querySelector('.mtoc-sheet') as HTMLElement;
    const links = Array.from(mtoc.querySelectorAll('.mtoc-link')) as HTMLAnchorElement[];
    const h2s = Array.from(document.querySelectorAll('article h2[id]')) as HTMLElement[];
    let mtocReturn: HTMLElement | null = null;

    // 닫힘 상태에선 시트를 접근성 트리·탭 순서에서 제외
    sheet.setAttribute('inert', '');

    const currentIndex = () => {
      let idx = 0;
      h2s.forEach((h, i) => { if (h.getBoundingClientRect().top < 90) idx = i; });
      return idx;
    };
    const markCurrent = () => {
      const c = currentIndex();
      links.forEach((a, i) => a.classList.toggle('active', i === c));
      return c;
    };
    const openSheet = () => {
      const c = markCurrent();
      sheet.classList.add('is-open');
      backdrop.classList.add('is-open');
      sheet.removeAttribute('inert');
      fab.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      mtocReturn = document.activeElement as HTMLElement;
      const cur = links[c];
      if (cur) cur.scrollIntoView({ block: 'center' });
      sheet.focus();
    };
    const closeSheet = (restoreFocus = true) => {
      sheet.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      sheet.setAttribute('inert', '');
      fab.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      if (restoreFocus && mtocReturn) mtocReturn.focus();
      mtocReturn = null;
    };

    fab.addEventListener('click', openSheet);
    backdrop.addEventListener('click', () => closeSheet());
    // 항목 선택 시: 시트를 닫되 포커스는 본문 대상 절로 넘어가도록 복귀 생략
    links.forEach((a) => a.addEventListener('click', () => closeSheet(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && sheet.classList.contains('is-open')) closeSheet();
    });

    // FAB 등장/숨김: 헤더를 지나면 등장, 최하단(다음글·푸터)에선 숨김
    const onScroll = () => {
      const y = window.scrollY;
      const max = document.documentElement.scrollHeight - window.innerHeight;
      fab.classList.toggle('is-visible', y > 140 && y < max - 160);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
